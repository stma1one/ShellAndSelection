<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="DIExample.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:DIExample"
    xmlns:views="clr-namespace:DIExample.Views"
    Title="DIExample">

    <Shell.FlyoutHeader>
        <StackLayout
            Padding="20"
            BackgroundColor="#2196F3"
            VerticalOptions="Center">
            <Label
                FontAttributes="Bold"
                FontSize="24"
                HorizontalOptions="Center"
                Text="ברוכים הבאים!" />
        </StackLayout>
    </Shell.FlyoutHeader>
    <Shell.FlyoutFooter>
        <HorizontalStackLayout
            Padding="20"
            BackgroundColor="#2196F3"
            VerticalOptions="Center">
            <Label
                FontAttributes="Bold"
                FontSize="24"
                HorizontalOptions="Center"
                Text="נוצר על ידי טל" />
        </HorizontalStackLayout>
    </Shell.FlyoutFooter>
    <ShellContent
        Title="מסך פתיחה"
        ContentTemplate="{DataTemplate views:HomePage}"
        Icon="favorite.png"
        Route="HomePage" />
    <ShellContent
        Title="ריכוז תוצאות"
        ContentTemplate="{DataTemplate views:ScorePage}"
        Icon="delete.png"
        Route="TotalScores" />
    <FlyoutItem FlyoutIcon="dotnet_bot.png">

        <ShellContent
            Title="כניסת משתמש"
            ContentTemplate="{DataTemplate views:LoginUsernamePage}"
            Route="LoginPage" />
        <ShellContent
            Title="שחזור פרטי כניסה"
            ContentTemplate="{DataTemplate views:LoginContactPage}"
            Route="LoginContact" />

    </FlyoutItem>
</Shell>


