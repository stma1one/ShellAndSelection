<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="DIExample.Views.PlayerDetailsPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="פרטי שחקן">

    <!--  שימוש ב-ScrollView למקרה שהמסך יהיה קטן והתוכן יחרוג  -->
    <ScrollView>
        <!--  שימוש ב-Grid לפריסת כלל המסך  -->
        <Grid
            Padding="20"
            HorizontalOptions="Center"
            RowDefinitions="Auto, Auto, Auto, Auto"
            RowSpacing="20"
            VerticalOptions="Center">

            <!--  שורה 0: תמונת פרופיל מעוגלת  -->
            <Image
                Grid.Row="0"
                Aspect="AspectFill"
                HeightRequest="150"
                HorizontalOptions="Center"
                Source="{Binding Player.ProfileImage}"
                WidthRequest="150">
                <Image.Clip>
                    <EllipseGeometry
                        Center="75,75"
                        RadiusX="75"
                        RadiusY="75" />
                </Image.Clip>
            </Image>

            <!--  שורה 1: שם השחקן  -->
            <Label
                Grid.Row="1"
                FontAttributes="Bold"
                FontSize="32"
                HorizontalOptions="Center"
                Text="{Binding Player.Name}"
                TextColor="Black" />

            <!--  שורה 2: כרטיס המציג את הניקוד באמצעות Border  -->
            <Border
                Grid.Row="2"
                Padding="20"
                BackgroundColor="#F0F0F0">

                <!--  עיצוב ה-Border: פינות מעוגלות וצללית  -->
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="15" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow
                        Brush="Black"
                        Opacity="0.2"
                        Radius="5"
                        Offset="0,2" />
                </Border.Shadow>

                <!--  שימוש ב-Grid פנימי לסידור הטקסטים בתוך ה-Border  -->
                <Grid
                    HorizontalOptions="Center"
                    RowDefinitions="Auto, Auto"
                    RowSpacing="10">
                    <Label
                        Grid.Row="0"
                        FontSize="18"
                        HorizontalOptions="Center"
                        Text="ניקוד נוכחי"
                        TextColor="Gray" />

                    <Label
                        Grid.Row="1"
                        FontAttributes="Bold"
                        FontSize="48"
                        HorizontalOptions="Center"
                        Text="{Binding Player.Score}"
                        TextColor="Green" />
                </Grid>
            </Border>

            <!--  שורה 3: תאריך משחק אחרון  -->
            <!--  השארתי כאן HorizontalStackLayout כי מדובר בשני פריטים בשורה אחת  -->
            <HorizontalStackLayout
                Grid.Row="3"
                HorizontalOptions="Center"
                Spacing="10">
                <Label
                    FontSize="16"
                    Text="תאריך:"
                    TextColor="Gray" />
                <Label
                    FontAttributes="Bold"
                    FontSize="16"
                    Text="{Binding Player.Date, StringFormat='{0:dd/MM/yyyy}'}" />
            </HorizontalStackLayout>

        </Grid>
    </ScrollView>
</ContentPage>