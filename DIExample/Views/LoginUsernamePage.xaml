<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="DIExample.Views.LoginUsernamePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewmodels="clr-namespace:DIExample.ViewModels"
    Title="כניסה עם שם משתמש"
    x:DataType="viewmodels:LoginUsernameViewModel">

    <Grid
        Padding="30"
        RowDefinitions="Auto, *, Auto"
        RowSpacing="20"
        VerticalOptions="Center">

        <Label
            Grid.Row="0"
            FontAttributes="Bold"
            FontSize="32"
            HorizontalOptions="Center"
            Text="התחברות" />

        <Border
            Grid.Row="1"
            Padding="20"
            StrokeShape="RoundRectangle 15">
            <Grid RowDefinitions="Auto, Auto, Auto, Auto" RowSpacing="15">
                <Label Grid.Row="0" Text="שם משתמש" />
                <Entry
                    Grid.Row="1"
                    Placeholder="הכנס שם משתמש"
                    Text="{Binding Username}" />

                <Label Grid.Row="2" Text="סיסמה" />
                <Entry
                    Grid.Row="3"
                    IsPassword="True"
                    Placeholder="הכנס סיסמה"
                    Text="{Binding Password}" />
            </Grid>
        </Border>

        <Button
            Grid.Row="2"
            Command="{Binding LoginCommand}"
            CornerRadius="10"
            HeightRequest="50"
            Text="התחבר" />
    </Grid>
</ContentPage>